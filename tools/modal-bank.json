          "word": "don't have to",
          "palette_key": "ERROR",
          "ok": false,
          "gloss": "Incorrect meaning",
          "note": "'Don't have to' signals no obligation — the opposite of advice against something. A very common learner error."
        }
      ]
    },
    {
      "id": "crit-001",
      "function": "criticism_past",
      "cefr": "B2",
      "register": "neutral",
      "dangerous_pairs": [
        "should have/could have",
        "should have/must have"
      ],
      "context": "A student missed an important deadline.",
      "before": "You",
      "after": "told me earlier.",
      "slot_after_modal": "have",
      "modals": [
        {
          "word": "should have",
          "palette_key": "should have",
          "ok": true,
          "gloss": "Mild criticism / regret",
          "note": "The standard choice to point out what someone failed to do but ought to have done."
        },
        {
          "word": "could have",
          "palette_key": "could have",
          "ok": true,
          "gloss": "Missed opportunity",
          "note": "Softer than 'should have'. It highlights the overlooked possibility rather than the failure itself."
        },
        {
          "word": "might have",
          "palette_key": "might have",
          "ok": true,
          "gloss": "Very soft reproach",
          "note": "The gentlest option — phrasing the criticism almost as a subtle hint rather than a direct complaint."
        },
        {
          "word": "ought to have",
          "palette_key": "ought to have",
          "ok": true,
          "gloss": "Formal criticism",
          "note": "Virtually identical in meaning to 'should have', simply more elevated in register."
        },
        {
          "word": "must have",
          "palette_key": "must have",
          "ok": false,
          "gloss": "Incorrect meaning",
          "note": "'Must have told me' shifts the function entirely — it becomes a deduction ('I'm certain you told me'), stripping away the criticism."
        }
      ]
    },
    {
