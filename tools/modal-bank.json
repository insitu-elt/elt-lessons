  "sentences": [
    {
      "id": "cond-001",
      "function": "first_conditional",
      "cefr": "B1",
      "register": "neutral",
      "dangerous_pairs": [
        "will/should",
        "will/might"
      ],
      "context": "A manager speaking encouragingly to an employee.",
      "before": "If you finish the report,",
      "after": "feel proud.",
      "slot_after_modal": "you",
      "modals": [
        {
          "word": "will",
          "palette_key": "will",
          "ok": true,
          "gloss": "Confident prediction",
          "note": "The most neutral choice — a straightforward promise about the result."
        },
        {
          "word": "should",
          "palette_key": "should",
          "ok": true,
          "gloss": "Reasonable expectation",
          "note": "Slightly more tentative than 'will'. The outcome is likely but not guaranteed."
        },
        {
          "word": "might",
          "palette_key": "might",
          "ok": true,
          "gloss": "Tentative possibility",
          "note": "Much weaker. The speaker isn't very sure — feelings are unpredictable."
        },
        {
          "word": "must",
          "palette_key": "must",
          "ok": true,
          "gloss": "Strong inference",
          "note": "Sounds almost like a logical conclusion: given how hard you worked, pride is the only possible response."
        },
        {
          "word": "shall",
          "palette_key": "ERROR",
          "ok": false,
          "gloss": "Not used in modern neutral English",
          "note": "'Shall' is archaic or legalistic here. You'd only meet it in very formal or old-fashioned writing."
        }
      ]
    },
    {
      "id": "cond-002",
      "function": "first_conditional",
      "cefr": "B1",
      "register": "neutral",
      "dangerous_pairs": [
        "will/can",
        "can/could"
      ],
      "context": "Two friends planning a picnic, looking at the sky.",
      "before": "If the weather stays fine,",
      "after": "eat outside.",
      "slot_after_modal": "we",
      "modals": [
        {
          "word": "will",
          "palette_key": "will",
          "ok": true,
          "gloss": "Firm plan",
          "note": "A confident intention — the picnic is on."
        },
        {
          "word": "can",
          "palette_key": "can",
          "ok": true,
          "gloss": "Possibility opens up",
          "note": "Frames the fine weather as unlocking an option that isn't currently available."
        },
        {
          "word": "could",
          "palette_key": "could",
          "ok": true,
          "gloss": "Softer suggestion",
          "note": "A gentle proposal — more exploratory than 'can', slightly hypothetical in feel."
        },
        {
          "word": "might",
          "palette_key": "might",
          "ok": true,
          "gloss": "Undecided",
          "note": "The speaker hasn't committed yet — eating outside is one of several options."
        },
        {
          "word": "should",
          "palette_key": "should",
          "ok": true,
          "gloss": "Recommendation",
          "note": "Frames eating outside as the right thing to do — almost an obligation to enjoy the weather."
        }
      ]
    },
    {
      "id": "spec-001",
      "function": "speculation_present",
      "cefr": "B1",
      "register": "neutral",
      "dangerous_pairs": [
        "must/might",
        "might/could"
      ],
      "context": "Looking at a dark house across the street. No lights, no car in the drive.",
      "before": "They",
      "after": "be away on holiday.",
      "slot_after_modal": "",
      "modals": [
        {
          "word": "must",
          "palette_key": "must",
          "ok": true,
          "gloss": "Near-certain deduction",
          "note": "The visual evidence is strong. You are highly confident — perhaps 95% sure."
        },
        {
          "word": "might",
          "palette_key": "might",
          "ok": true,
          "gloss": "One possible reality",
          "note": "About 50-50 — they might be away, or they might just be out for the evening."
        },
        {
          "word": "could",
          "palette_key": "could",
          "ok": true,
          "gloss": "Weaker possibility",
          "note": "Similar to 'might' but slightly more neutral — flagging something as technically possible without committing."
        },
        {
          "word": "may",
          "palette_key": "may",
          "ok": true,
          "gloss": "Formal possibility",
          "note": "Very close in meaning to 'might', just a touch more formal in tone."
        },
        {
          "word": "can",
          "palette_key": "ERROR",
          "ok": false,
          "gloss": "Incorrect usage",
          "note": "'Can' works for general theoretical possibility ('accidents can happen') but is not used for guessing about a specific, current situation."
        }
      ]
    },
    {
      "id": "spec-002",
      "function": "speculation_past",
      "cefr": "B2",
      "register": "neutral",
      "dangerous_pairs": [
        "must have/might have",
        "should have/must have"
      ],
      "context": "A colleague didn't come to the meeting. You're guessing why.",
      "before": "She",
      "after": "forgotten about it.",
      "slot_after_modal": "have",
      "modals": [
        {
          "word": "must have",
          "palette_key": "must have",
          "ok": true,
          "gloss": "Confident past deduction",
          "note": "You are almost entirely sure this is the reason. The evidence points strongly here."
        },
        {
          "word": "might have",
          "palette_key": "might have",
          "ok": true,
          "gloss": "Possible past explanation",
          "note": "A viable possibility, but you acknowledge there are other potential explanations too."
        },
        {
          "word": "could have",
          "palette_key": "could have",
          "ok": true,
          "gloss": "Hypothetical past possibility",
          "note": "Very close to 'might have'. Both function well here."
        },
        {
          "word": "may have",
          "palette_key": "may have",
          "ok": true,
          "gloss": "Formal past possibility",
          "note": "The formal equivalent of 'might have' — commonly found in professional writing and news reports."
        },
        {
          "word": "should have",
          "palette_key": "ERROR",
          "ok": false,
          "gloss": "Illogical meaning",
          "note": "Grammatically correct, but logically wrong. 'Should have forgotten' implies she was supposed to forget — which makes no sense here."
        }
      ]
    },
    {
      "id": "adv-001",
      "function": "advice",
